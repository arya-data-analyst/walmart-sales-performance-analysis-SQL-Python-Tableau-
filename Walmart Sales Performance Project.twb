      <aliases enabled='yes' />
      <column datatype='string' name='[Branch]' role='dimension' type='nominal' />
      <column caption='Total Sales' datatype='real' name='[Calculation_0726827195625472]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[unit_price] * [quantity]' />
      </column>
      <column caption='Total Profit' datatype='real' name='[Calculation_0726827195842561]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0726827195625472] * [profit_margin]' />
      </column>
      <column caption='Total Quantity Sold' datatype='integer' name='[Calculation_0726827197067266]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([quantity])' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_0726827197239299]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0726827195625472]) / COUNT([invoice_id])' />
      </column>
      <column caption='zero axis' datatype='integer' name='[Calculation_0726827201302532]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0' />
      </column>
      <column caption='Hour' datatype='datetime' datatype-customized='true' name='[Calculation_0726827208785925]' role='dimension' type='quantitative'>
        <calculation class='tableau' formula='DATEPARSE ( &quot;dd&quot;, STR(DATEPART(&apos;hour&apos;,[time])) ) ' />
      </column>
